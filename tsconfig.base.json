{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    "useDefineForClassFields": true,
    "baseUrl": ".",
    "paths": {
      "@manifesto-ai/studio-core": ["packages/studio-core/src/index.ts"],
      "@manifesto-ai/studio-node": ["packages/studio-node/src/index.ts"],
      "@manifesto-ai/ui-core": ["packages/ui-core/src/index.ts"],
      "@manifesto-ai/ui-core/*": ["packages/ui-core/src/*"],
      "@manifesto-ai/studio-ui": ["packages/studio-ui/src/index.ts"],
      "@manifesto-ai/studio-ui/*": ["packages/studio-ui/src/*"]
    }
  }
}
