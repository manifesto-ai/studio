{
  "name": "@manifesto-ai/studio-core",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/manifesto-ai/studio",
    "directory": "packages/studio-core"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@manifesto-ai/core": "^2.9.0",
    "@manifesto-ai/sdk": "^3.4.0"
  },
  "devDependencies": {
    "@manifesto-ai/codegen": "^0.2.3",
    "@manifesto-ai/compiler": "^3.1.1",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4"
  }
}
