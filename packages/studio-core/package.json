{
  "name": "@manifesto-ai/studio-core",
  "version": "0.0.0",
  "description": "Widget-independent core for the Manifesto Studio Editor",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sqlite": {
      "types": "./dist/sqlite.d.ts",
      "import": "./dist/sqlite.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsup",
    "clean": "rm -rf dist",
    "lint": "echo 'lint not configured'",
    "test": "node ../../node_modules/vitest/vitest.mjs run",
    "test:watch": "node ../../node_modules/vitest/vitest.mjs"
  },
  "dependencies": {
    "@manifesto-ai/compiler": "^3.8.0",
    "@manifesto-ai/lineage": "^3.10.3",
    "@manifesto-ai/sdk": "^3.18.0",
    "better-sqlite3": "^12.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13"
  },
  "files": [
    "dist"
  ]
}
