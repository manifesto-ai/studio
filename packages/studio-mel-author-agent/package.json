{
  "name": "@manifesto-ai/studio-mel-author-agent",
  "version": "0.0.0",
  "description": "Headless MEL authoring agent workspace and tools for Manifesto Studio",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./guide": {
      "types": "./dist/guide.d.ts",
      "import": "./dist/guide.js"
    }
  },
  "scripts": {
