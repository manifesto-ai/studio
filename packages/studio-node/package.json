{
  "name": "@manifesto-ai/studio-node",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/manifesto-ai/studio",
    "directory": "packages/studio-node"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@manifesto-ai/compiler": "^3.1.1",
    "@manifesto-ai/studio-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0"
  }
}
