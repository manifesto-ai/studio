// studio.mel — Studio UI contract (v0).
//
// This is *not* the user's domain. It is the contract between the
// agent, the user, and the Studio UI: the semantic transitions the
// UI is allowed to make, with legality gates enforcing mutual
// exclusions.
//
// Rule of thumb for what lives here:
//   - Must be a meaningful semantic transition the agent/user could
//     request and that would benefit from a legality gate.
//   - Must NOT be ephemeral (animations, trace playback, scrub tween,
//     debounced cursor stream, dispatch logs) — those live in React /
//     XState as side effects of the transitions declared here.

domain Studio {
  type FocusKind = "action" | "state" | "computed"
  type FocusOrigin = "graph" | "source" | "diagnostic" | "interact" | "agent"
  type LensId = "interact" | "snapshot" | "plan" | "history" | "diagnostics" | "agent"
  // Agent turn = a Manifesto-owned LLM turn lifecycle. `live` is the
  // AgentLens path. Status lives in the runtime so the harness can
  // resume until the model structurally ends the turn through endTurn.
  type AgentTurnMode = "live"
  type AgentTurnStatus = "running" | "ended"
  type AgentToolName =
    "inspectToolAffordances"
    | "inspectFocus"
    | "studioDispatch"
    | "inspectSnapshot"
    | "inspectAvailability"
    | "inspectNeighbors"
    | "explainLegality"
    | "simulateIntent"
    | "dispatch"
    | "endTurn"
  // ViewMode is the mutual-exclusion discriminator for "what view of
  // reality the Studio is currently presenting". `live` is the normal
  // case; `simulate` is a what-if preview against the live snapshot;
  // `scrub` is a point-in-time view of past schema state. The
  // runtime's `dispatchable when` gates below enforce that the three
  // modes never overlap.
  type ViewMode = "live" | "simulate" | "scrub"

  state {
    // ── Focus ──────────────────────────────────────────────────────
    // The currently-selected graph node. `focusedNodeId` encodes the
    // node's kind + name in the existing `<kind>:<name>` format the
    // webapp already uses (e.g. "action:toggleTodo"). Kind and origin
    // are kept as sibling fields so the agent can read them without
    // parsing the id.
    focusedNodeId: string | null = null
    focusedNodeKind: FocusKind | null = null
    focusedNodeOrigin: FocusOrigin | null = null

    // ── Lens ───────────────────────────────────────────────────────
    activeLens: LensId = "interact"

    // ── View mode (mutual exclusion: live / simulate / scrub) ──────
    viewMode: ViewMode = "live"
    // Which action is currently being what-if'd. Non-null iff
    // viewMode == "simulate". The playback trace itself lives in
    // React state (ephemeral).
    simulationActionName: string | null = null
    // Which edit-envelope the user is scrubbing to. Non-null iff
    // viewMode == "scrub". The replayed module/snapshot live in
    // React state (expensive, derivable).
    scrubEnvelopeId: string | null = null

    // ── Active project ─────────────────────────────────────────────
    // Which bundled project the user is editing. Project source
    // itself is owned by the Monaco editor — NOT mirrored here.
    activeProjectName: string | null = null

    // ── Agent interaction memory (single-entry) ────────────────────
    // We deliberately store only the LATEST turn — the full transcript
    // lives in React state (ephemeral, cheap to lose, replayable).
    // The value here exists so the agent can call `inspectFocus` and
    // see what the user/it last said without needing access to a
    // separate transcript store, AND so every interaction advances
    // studio.mel's lineage — making the agent's timeline a first-
    // class part of runtime history (scrubbable alongside UI state
    // changes).
    lastUserPrompt: string | null = null
    lastAgentAnswer: string | null = null
    agentTurnCount: number = 0

    // ── Active agent turn lifecycle ────────────────────────────────
    // Persisted turn state. A turn is running from beginAgentTurn
    // until the model itself calls endTurn, which dispatches
    // concludeAgentTurn. Anything in between — dropped streams,
    // refreshed browser, model ramble — leaves the turn running so
    // the harness can resume. Timestamps are intentionally NOT stored
    // here (determinism discipline) — React shell correlates with its
    // own clock.
    agentTurnId: string | null = null
    agentTurnMode: AgentTurnMode | null = null
    agentTurnStatus: AgentTurnStatus | null = null
    agentTurnPrompt: string | null = null
    agentTurnConclusion: string | null = null
    agentTurnResendCount: number = 0
    // Tool-result progress guard. The harness records tool outcomes
    // here; studio.mel owns the no-progress interpretation. Repeating
    // the same failing tool result ends the active turn instead of
    // allowing an infinite resend loop.
    agentLastToolResultName: string | null = null
    agentLastToolFailureKey: string | null = null
    agentLastToolFailureReason: string | null = null
    agentToolFailureRepeatCount: number = 0
    agentLastToolSuccessKey: string | null = null
    agentToolSuccessRepeatCount: number = 0
    agentToolLoopBlockReason: string | null = null
    agentLastModelFinishKey: string | null = null
    agentModelFinishRepeatCount: number = 0
    // Tool admission context. Host runtimes synchronize the user
    // domain's coarse state into this contract; Studio MEL owns the
    // actual per-tool admission gates below.
    agentUserModuleReady: boolean = false
    agentMelSourceNonEmpty: boolean = false
    agentFocusedActionName: string | null = null
    agentFocusedActionAvailable: boolean = false
    agentLastAdmittedToolName: string | null = null
  }

  computed hasFocus = focusedNodeId != null
  computed isLive = viewMode == "live"
  computed isSimulating = viewMode == "simulate"
  computed isScrubbing = viewMode == "scrub"
  computed agentToolLoopBlocked = agentToolFailureRepeatCount >= 2 || agentToolSuccessRepeatCount >= 2 || agentModelFinishRepeatCount >= 2
  computed agentHasFocusedAction = agentFocusedActionName != null

  // ── Focus actions ────────────────────────────────────────────────

  action focusNode(id: string, kind: FocusKind, origin: FocusOrigin) {
    onceIntent {
      patch focusedNodeId = id
      patch focusedNodeKind = kind
      patch focusedNodeOrigin = origin
    }
  }

  action clearFocus() {
    onceIntent {
      patch focusedNodeId = null
      patch focusedNodeKind = null
      patch focusedNodeOrigin = null
    }
  }

  // ── Lens action ──────────────────────────────────────────────────

  action openLens(id: LensId) {
    onceIntent {
      patch activeLens = id
    }
  }

  // ── Simulation actions ──────────────────────────────────────────
  // Entering simulation requires the Studio be live — you cannot
  // what-if against a scrubbed past snapshot. Exiting is only valid
  // while simulating. This is the heart of what studio.mel buys us:
  // impossible UI transitions are rejected at the runtime boundary.

  action enterSimulation(actionName: string)
    dispatchable when viewMode == "live"
  {
    onceIntent {
      patch viewMode = "simulate"
      patch simulationActionName = actionName
    }
  }

  action exitSimulation()
    dispatchable when viewMode == "simulate"
  {
    onceIntent {
      patch viewMode = "live"
      patch simulationActionName = null
    }
  }

  // ── Scrub actions ───────────────────────────────────────────────
  // Scrubbing is allowed from live (entering) or from scrub
  // (switching target). Simulation blocks entry — agent that wants
  // both must exit simulation first.

  action scrubTo(envelopeId: string)
    dispatchable when viewMode == "live" || viewMode == "scrub"
  {
    onceIntent {
      patch viewMode = "scrub"
      patch scrubEnvelopeId = envelopeId
    }
  }

  action resetScrub()
    dispatchable when viewMode == "scrub"
  {
    onceIntent {
      patch viewMode = "live"
      patch scrubEnvelopeId = null
    }
  }

  // ── Project switching ───────────────────────────────────────────
  // Switching projects resets focus and view mode — the old focus
  // refers to a node id in the previous project and is no longer
  // meaningful. Mode resets to live since the old simulation/scrub
  // target belonged to the previous snapshot history.

  action switchProject(name: string) {
    onceIntent {
      patch activeProjectName = name
      patch focusedNodeId = null
      patch focusedNodeKind = null
      patch focusedNodeOrigin = null
      patch viewMode = "live"
      patch simulationActionName = null
      patch scrubEnvelopeId = null
    }
  }

  // ── Agent turn record ───────────────────────────────────────────
  // Called by the React shell when an agent turn finalizes. Each
  // call advances studio.mel's lineage by one world — meaning
  // "which turn are we on" is queryable via the lineage tracker
  // without a separate chat-history store.
  //
  // `answer` is the finalized assistant text (tool-call-only turns
  // pass a short human-readable summary). We intentionally keep
  // only the latest turn as state — the full transcript lives in
  // React and can be long; what the runtime cares about is *the
  // lineage of the conversation existing*, not its full content.

  action recordAgentTurn(prompt: string, answer: string) {
    onceIntent {
      patch lastUserPrompt = prompt
      patch lastAgentAnswer = answer
      patch agentTurnCount = agentTurnCount + 1
    }
  }

  // ── Agent tool admission ────────────────────────────────────────
  // Tool implementations live in the host, but the identity and
  // availability of tools visible to the LLM live here. The host
  // synchronizes only coarse user-runtime facts; every actual tool
  // call must first dispatch requestTool(tool).

  action syncAgentToolContext(
    userModuleReady: boolean,
    melSourceNonEmpty: boolean,
    focusedActionName: string | null,
    focusedActionAvailable: boolean
  ) {
    onceIntent {
      patch agentUserModuleReady = userModuleReady
      patch agentMelSourceNonEmpty = melSourceNonEmpty
      patch agentFocusedActionName = focusedActionName
      patch agentFocusedActionAvailable = focusedActionAvailable
    }
  }

  action requestTool(tool: AgentToolName)
    available when agentTurnStatus == "running"
    dispatchable when match(
      tool,
      ["inspectSnapshot", agentUserModuleReady],
      ["inspectAvailability", agentUserModuleReady],
      ["inspectNeighbors", agentUserModuleReady],
      ["explainLegality", agentUserModuleReady],
      ["simulateIntent", agentUserModuleReady && viewMode == "live"],
      ["dispatch", agentUserModuleReady],
      true
    )
  {
    onceIntent {
      patch agentLastAdmittedToolName = tool
    }
  }

  // ── Agent turn lifecycle ────────────────────────────────────────
  // Only the React/LLM harness calls beginAgentTurn (on user prompt)
  // and the model calls endTurn, which dispatches concludeAgentTurn.
  // beginAgentTurn is idempotent across "ended"
  // turns — starting a new one always resets resend count and
  // conclusion. It is rejected while a prior turn is still running
  // so double-sends don't stomp.

  action beginAgentTurn(id: string, mode: AgentTurnMode, prompt: string)
    dispatchable when agentTurnStatus == null || agentTurnStatus == "ended"
  {
    onceIntent {
      patch agentTurnId = id
      patch agentTurnMode = mode
      patch agentTurnStatus = "running"
      patch agentTurnPrompt = prompt
      patch agentTurnConclusion = null
      patch agentTurnResendCount = 0
      patch agentLastToolResultName = null
      patch agentLastToolFailureKey = null
      patch agentLastToolFailureReason = null
      patch agentToolFailureRepeatCount = 0
      patch agentLastToolSuccessKey = null
      patch agentToolSuccessRepeatCount = 0
      patch agentToolLoopBlockReason = null
      patch agentLastModelFinishKey = null
      patch agentModelFinishRepeatCount = 0
      patch agentLastAdmittedToolName = null
    }
  }

  // The LLM harness records each tool outcome, but the loop policy
  // lives here. One repeated failure is recoverable: the model can
  // inspect the structured error and choose another path. Repeating
  // the same success or failure without a terminal endTurn is no
  // progress, so this action ends the turn from inside the Studio
  // runtime.

  action recordAgentToolResult(
    toolName: string,
    toolResultKey: string,
    ok: boolean,
    reason: string
  )
    dispatchable when agentTurnStatus == "running"
  {
    onceIntent {
      patch agentToolFailureRepeatCount =
        ok ? 0 : (agentLastToolFailureKey == toolResultKey ? agentToolFailureRepeatCount + 1 : 1)
      patch agentToolSuccessRepeatCount =
        ok ? (agentLastToolSuccessKey == toolResultKey ? agentToolSuccessRepeatCount + 1 : 1) : 0
      patch agentToolLoopBlockReason =
        ok
          ? (agentLastToolSuccessKey == toolResultKey && agentToolSuccessRepeatCount >= 1 ? reason : null)
          : (agentLastToolFailureKey == toolResultKey && agentToolFailureRepeatCount >= 1 ? reason : null)
      patch agentTurnStatus =
        (
          ok
            ? agentLastToolSuccessKey == toolResultKey && agentToolSuccessRepeatCount >= 1
            : agentLastToolFailureKey == toolResultKey && agentToolFailureRepeatCount >= 1
        ) ? "ended" : agentTurnStatus
      patch agentTurnConclusion =
        (
          ok
            ? agentLastToolSuccessKey == toolResultKey && agentToolSuccessRepeatCount >= 1
            : agentLastToolFailureKey == toolResultKey && agentToolFailureRepeatCount >= 1
        ) ? reason : agentTurnConclusion
      patch agentLastToolResultName = toolName
      patch agentLastToolFailureKey = ok ? null : toolResultKey
      patch agentLastToolFailureReason = ok ? null : reason
      patch agentLastToolSuccessKey = ok ? toolResultKey : null
    }
  }

  // Called once per assistant finish while a turn is still running.
  // The normal terminal path is still the explicit endTurn tool. This
  // action covers non-terminal finishes so the runtime, not prompt
  // prose, owns the escape hatch:
  // - text with no tool call is treated as a completed answer and
  //   ends the turn even if the model forgot endTurn
  // - repeated reasoning-only finishes end as no progress
  // - tool-call finishes stay running; tool result guards above catch
  //   repeated successful/failed calls

  action recordAgentModelFinish(
    finishKey: string,
    hasText: boolean,
    hasToolCalls: boolean,
    reason: string
  )
    dispatchable when agentTurnStatus == "running"
  {
    onceIntent {
      patch agentModelFinishRepeatCount =
        agentLastModelFinishKey == finishKey ? agentModelFinishRepeatCount + 1 : 1
      patch agentToolLoopBlockReason =
        hasText && hasToolCalls == false
          ? null
          : (
              hasToolCalls
                ? agentToolLoopBlockReason
                : (agentLastModelFinishKey == finishKey && agentModelFinishRepeatCount >= 1 ? reason : agentToolLoopBlockReason)
            )
      patch agentTurnStatus =
        hasText && hasToolCalls == false
          ? "ended"
          : (
              hasToolCalls
                ? agentTurnStatus
                : (agentLastModelFinishKey == finishKey && agentModelFinishRepeatCount >= 1 ? "ended" : agentTurnStatus)
            )
      patch agentTurnConclusion =
        hasText && hasToolCalls == false
          ? reason
          : (
              hasToolCalls
                ? agentTurnConclusion
                : (agentLastModelFinishKey == finishKey && agentModelFinishRepeatCount >= 1 ? reason : agentTurnConclusion)
            )
      patch agentTurnResendCount =
        hasText && hasToolCalls == false ? agentTurnResendCount : agentTurnResendCount + 1
      patch agentLastModelFinishKey = finishKey
    }
  }

  action concludeAgentTurn(answer: string)
    dispatchable when agentTurnStatus == "running"
  {
    onceIntent {
      patch agentTurnStatus = "ended"
      patch agentTurnConclusion = answer
    }
  }

  action cancelAgentTurn(reason: string)
    dispatchable when agentTurnStatus == "running"
  {
    onceIntent {
      patch agentTurnStatus = "ended"
      patch agentTurnConclusion = reason
    }
  }

  // Called by the harness every time it re-invokes the LLM within a
  // running turn. The count is observational; the user remains in
  // control of stopping a long-running turn.

  action incrementAgentTurnResend()
    dispatchable when agentTurnStatus == "running"
  {
    onceIntent {
      patch agentTurnResendCount = agentTurnResendCount + 1
    }
  }
}
